#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="$(readlink -f -- "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd -- "$(dirname -- "$SCRIPT_PATH")" && pwd)"
DEFAULT_PROJECT_ROOT="$(cd -- "$SCRIPT_DIR/.." && pwd)"
DEFAULT_HOME_DIR="/home/haman"
HOME_DIR="${HOME:-$DEFAULT_HOME_DIR}"
PROJECT_ROOT="${PROJECT_ROOT:-$DEFAULT_PROJECT_ROOT}"
RELAY_BIN="${RELAY_BIN:-$PROJECT_ROOT/bin/picoclaw-ops-relay}"
mode="generic"
limit="10"

if [ -z "${HOME:-}" ]; then
  export HOME="$HOME_DIR"
fi

export PATH="$HOME_DIR/.local/bin:$HOME_DIR/.nvm/versions/node/v22.20.0/bin:/usr/local/bin:/usr/bin:/bin"

while [ $# -gt 0 ]; do
  case "$1" in
    --mode)
      if [ $# -lt 2 ]; then
        echo "missing value for --mode" >&2
        exit 2
      fi
      mode="$2"
      shift 2
      ;;
    --limit)
      if [ $# -lt 2 ]; then
        echo "missing value for --limit" >&2
        exit 2
      fi
      limit="$2"
      shift 2
      ;;
    *)
      break
      ;;
  esac
done

sender="${1:-}"
owner="${2:-}"
repo="${3:-}"
shift 3 || true
query="${*:-}"

if [ -z "$sender" ] || [ -z "$owner" ] || [ -z "$repo" ] || [ -z "$query" ]; then
  echo "Usage: ops-github-research [--mode MODE] [--limit N] SENDER OWNER REPO QUERY..." >&2
  exit 2
fi

exec "$RELAY_BIN" github-research \
  --sender "$sender" \
  --repo "$owner/$repo" \
  --query "$query" \
  --mode "$mode" \
  --limit "$limit"
