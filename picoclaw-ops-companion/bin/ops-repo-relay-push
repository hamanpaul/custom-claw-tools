#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="$(readlink -f -- "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd -- "$(dirname -- "$SCRIPT_PATH")" && pwd)"
DEFAULT_PROJECT_ROOT="$(cd -- "$SCRIPT_DIR/.." && pwd)"
DEFAULT_HOME_DIR="/home/haman"
HOME_DIR="${HOME:-$DEFAULT_HOME_DIR}"
PROJECT_ROOT="${PROJECT_ROOT:-$DEFAULT_PROJECT_ROOT}"
RELAY_BIN="${RELAY_BIN:-$PROJECT_ROOT/bin/picoclaw-ops-relay}"
remote=""
branch=""
revision=""
transport=""
no_execute=0

if [ -z "${HOME:-}" ]; then
  export HOME="$HOME_DIR"
fi

export PATH="$HOME_DIR/.local/bin:$HOME_DIR/.nvm/versions/node/v22.20.0/bin:/usr/local/bin:/usr/bin:/bin"

while [ $# -gt 0 ]; do
  case "$1" in
    --remote)
      remote="${2:-}"
      shift 2
      ;;
    --branch)
      branch="${2:-}"
      shift 2
      ;;
    --revision)
      revision="${2:-}"
      shift 2
      ;;
    --transport)
      transport="${2:-}"
      shift 2
      ;;
    --no-execute)
      no_execute=1
      shift
      ;;
    *)
      break
      ;;
  esac
done

sender="${1:-}"
repo_path="${2:-}"

if [ -z "$sender" ] || [ -z "$repo_path" ]; then
  echo "Usage: ops-repo-relay-push [--remote NAME] [--branch NAME] [--revision REV] [--transport relay|bundle] [--no-execute] SENDER REPO_PATH" >&2
  exit 2
fi

cmd=(
  "$RELAY_BIN"
  repo-relay-push
  --sender "$sender"
  --repo-path "$repo_path"
)

if [ -n "$remote" ]; then
  cmd+=(--remote "$remote")
fi

if [ -n "$branch" ]; then
  cmd+=(--branch "$branch")
fi

if [ -n "$revision" ]; then
  cmd+=(--revision "$revision")
fi

if [ -n "$transport" ]; then
  cmd+=(--transport "$transport")
fi

if [ "$no_execute" -eq 1 ]; then
  cmd+=(--no-execute)
fi

exec "${cmd[@]}"
