#!/usr/bin/env python3
from __future__ import annotations

import os
import sys
from pathlib import Path


SKILL_NAME = "fami-claw-skill"
DEFAULT_HOME = Path("/home/haman/custom-claw-tools/famiclean-skill")
VALUE_OPTIONS = {
    "--home",
    "--env-file",
    "--device-ip",
    "--device-mac",
    "--broadcast-ip",
    "--port",
    "--timeout",
}
COMMAND_ALIASES = {
    "read-temp": "get-temp",
    "read-temperature": "get-temp",
    "water-temp": "get-temp",
    "water-temperature": "get-temp",
    "temp": "get-temp",
    "temperature": "get-temp",
    "status": "get-temp",
    "read-gas": "get-total-gas",
    "read-total-gas": "get-total-gas",
    "remaining-gas": "get-total-gas",
    "remaining-gas-amount": "get-total-gas",
    "total-gas": "get-total-gas",
    "gas": "get-total-gas",
    "usage": "get-total-gas",
    "set-temperature": "set-temp",
    "threshold-check": "check-threshold",
}


def iter_candidate_homes(wrapper_path: Path) -> list[Path]:
    candidates: list[Path] = []
    env_home = os.environ.get("FAMICLEAN_HOME")
    if env_home:
        candidates.append(Path(env_home).expanduser())
    candidates.append(wrapper_path.resolve().parent.parent.parent)
    candidates.append(DEFAULT_HOME)
    return candidates


def resolve_runtime(wrapper_path: Path) -> tuple[Path, Path]:
    seen: set[Path] = set()
    for home in iter_candidate_homes(wrapper_path):
        home = home.resolve()
        if home in seen:
            continue
        seen.add(home)
        cli_path = home / "skills" / SKILL_NAME / "scripts" / "famiclean.py"
        if cli_path.is_file():
            return home, cli_path
    raise SystemExit(
        "Unable to locate famiclean.py. Set FAMICLEAN_HOME or install the project "
        f"at {DEFAULT_HOME}."
    )


def find_command_index(args: list[str]) -> int | None:
    index = 0
    while index < len(args):
        token = args[index]
        if token in VALUE_OPTIONS:
            index += 2
            continue
        if token.startswith("-"):
            index += 1
            continue
        return index
    return None


def normalize_args(raw_args: list[str]) -> list[str]:
    if not raw_args or raw_args[0] in {"-h", "--help", "help"}:
        return ["--help"]

    args = [arg for arg in raw_args if arg != "--json"]
    command_index = find_command_index(args)
    if command_index is None:
        return ["--help"]

    args[command_index] = COMMAND_ALIASES.get(args[command_index], args[command_index])
    args.insert(command_index, "--json")
    return args


def main() -> int:
    home, cli_path = resolve_runtime(Path(__file__))
    forward_args = normalize_args(sys.argv[1:])
    if "--home" not in forward_args:
        forward_args = ["--home", str(home), *forward_args]
    os.execv(sys.executable, [sys.executable, str(cli_path), *forward_args])
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
