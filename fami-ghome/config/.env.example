# Runtime paths
# Defaults assume fami-ghome and famiclean-skill live side-by-side in this monorepo.
FAMICLEAN_HOME=../famiclean-skill
FAMICLEAN_WRAPPER=../famiclean-skill/skills/fami-claw-skill/fami-claw
FAMICLEAN_ENV_FILE=../famiclean-skill/config/.env
STATE_DIR=data
LOG_DIR=logs

# HTTP runtime
FAMI_GHOME_HOST=0.0.0.0
FAMI_GHOME_PORT=8787
PUBLIC_BASE_URL=https://ghome.example.com
TIMEZONE=Asia/Taipei
LOG_LEVEL=INFO
MAX_TEMP_CELSIUS=50

# Google Home Developer Console project
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_HOME_PROJECT_ID=
GOOGLE_HOME_FULFILLMENT_URL=https://ghome.example.com/fulfillment
GOOGLE_HOME_LOCAL_APP_ID=

# Account linking provider credentials
# Generate and manage these yourself, then copy them into Google Home Developer Console.
# They are used by Google against THIS service's /oauth/token endpoint.
# They are not Google Cloud OAuth client credentials and not Nest Device Access credentials.
ACCOUNT_LINKING_CLIENT_ID=
ACCOUNT_LINKING_CLIENT_SECRET=
ACCOUNT_LINKING_ALLOWED_REDIRECT_URIS=

# Single-home auth account for the authorize screen
# Store only a password hash here, never the raw password.
AUTH_ADMIN_USERNAME=
AUTH_ADMIN_PASSWORD_HASH=
# Generate 32+ random bytes for both values below.
SESSION_SECRET=
TOKEN_ENCRYPTION_KEY=

# OAuth token policy
AUTHORIZATION_CODE_TTL_SECONDS=300
ACCESS_TOKEN_TTL_SECONDS=3600
REFRESH_TOKEN_TTL_DAYS=180

# Local Home
LOCAL_HOME_ENABLED=false
LOCAL_HOME_DEVICE_ID=famiclean-water-heater-1
LOCAL_HOME_SCAN_PORT=3311
LOCAL_HOME_LISTEN_HOST=0.0.0.0
LOCAL_HOME_LISTEN_PORT=3322

# Optional Google APIs
GOOGLE_SERVICE_ACCOUNT_FILE=

# Diagnostics
INTERNAL_API_ENABLED=true
INTERNAL_API_TOKEN=
